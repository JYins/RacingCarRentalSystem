<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.rabbiter.vlm.dao.UseOrderDao">
	<resultMap id="UseOrderEntityMap" type="com.rabbiter.vlm.entity.UseOrderEntity">
		<id column="id" property="id" />
		<result column="car_name" property="carName" />
		<result column="car_type" property="carType" />
		<result column="brand" property="brand" />
		<result column="license_plate_number" property="licensePlateNumber" />
		<result column="hourly_price" property="hourlyPrice" />
		<result column="use_duration" property="useDuration" />
		<result column="total_price" property="totalPrice" />
		<result column="use_time" property="useTime" />
		<result column="username" property="username" />
		<result column="real_name" property="realName" />
		<result column="mobile_phone" property="mobilePhone" />
		<result column="is_reviewed" property="isReviewed" />
		<result column="review_response" property="reviewResponse" />
		<result column="is_paid" property="isPaid" />
		<result column="is_return" property="isReturn" />
		<result column="add_time" property="addTime" />
	</resultMap>

	<select id="selectListVO"
		resultType="com.rabbiter.vlm.entity.vo.UseOrderVO" >
		SELECT * FROM use_order use_order
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>

	<select id="selectVO"
		resultType="com.rabbiter.vlm.entity.vo.UseOrderVO" >
		SELECT  use_order.* FROM use_order use_order
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultMap="UseOrderEntityMap" >

		SELECT  * FROM use_order
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>

	<select id="selectView"
		resultMap="UseOrderEntityMap" >
		SELECT * FROM use_order <where> 1=1 ${ew.sqlSegment}</where>
	</select>

</mapper>
